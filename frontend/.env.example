# ============================================================
# HomeLens 프론트엔드 환경변수 설정 가이드
# ============================================================
# 1. 이 파일을 복사하여 .env.local 파일 생성:
#    cp .env.example .env.local       (macOS/Linux)
#    copy .env.example .env.local     (Windows)
# 2. .env.local 파일에 실제 값 입력
# 3. NEXT_PUBLIC_ 접두사 변수는 브라우저에 노출 — API 키 등 민감 정보 절대 금지
# ============================================================

# ===== 필수 =====

# 백엔드 API URL (브라우저에서 직접 호출)
# 로컬 개발: http://localhost:8000
# 프로덕션: https://home-lens-api.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ===== 선택 =====

# 카카오맵 API 키 (주소 자동완성 지도 미리보기 — 미설정 시 미표시)
# 발급: https://developers.kakao.com/
NEXT_PUBLIC_KAKAO_MAP_KEY=
