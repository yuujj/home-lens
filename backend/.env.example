# ============================================================
# HomeLens 백엔드 환경변수 설정 가이드
# ============================================================
# 1. 이 파일을 복사하여 .env 파일 생성:
#    cp .env.example .env       (macOS/Linux)
#    copy .env.example .env     (Windows)
# 2. .env 파일에 실제 API 키 값 입력
# 3. .env 파일은 .gitignore 포함 — 절대 커밋 금지
# ============================================================

# ===== 필수 (없으면 해당 기능 동작 불가) =====

# Claude AI API 키 — 등기부등본 텍스트 해석
# 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 공공데이터포털 인증키 — RTMS 실거래가 조회 (F001 시세 분석)
# 발급: https://www.data.go.kr/ → "국토교통부 아파트매매 실거래자료" 신청
DATA_GO_KR_API_KEY=

# 도로명주소 API 인증키 — 주소 정규화 및 법정동 코드 변환
# 발급: https://www.juso.go.kr/ → 개발자센터 → 사용승인신청
JUSO_API_KEY=

# ===== 선택 (없으면 해당 기능 fallback 처리) =====

# R-ONE 부동산원 API — 시세 트렌드 (없으면 RTMS 데이터만 사용)
# 발급: https://www.reb.or.kr/
RONE_API_KEY=

# 한국은행 ECOS API — 기준금리 조회 (없으면 하드코딩 값 사용)
# 발급: https://ecos.bok.or.kr/
ECOS_API_KEY=

# 금융감독원 금융상품 API — 시중금리 비교 (없으면 미사용)
# 발급: https://finlife.fss.or.kr/
FSS_API_KEY=

# ===== 서비스 설정 =====

# 프론트엔드에서 이 백엔드를 호출하는 URL
# 로컬: http://localhost:8000 / 프로덕션: https://home-lens-api.up.railway.app
BACKEND_URL=http://localhost:8000

# CORS 허용 출처 (쉼표 구분, 공백 없이)
# 로컬: http://localhost:3000 / 프로덕션: https://home-lens.vercel.app
CORS_ORIGINS=http://localhost:3000

# Supabase (MVP 미사용 — 향후 로그 저장 시 설정)
SUPABASE_URL=
SUPABASE_KEY=

# 시세 캐시 유효시간 (초 단위, 기본 1시간)
CACHE_TTL_SECONDS=3600

# 사용할 Claude 모델 ID
# 권장: claude-sonnet-4-6 (정확도↑) / claude-haiku-4-5-20251001 (속도↑·비용↓)
CLAUDE_MODEL=claude-sonnet-4-6
